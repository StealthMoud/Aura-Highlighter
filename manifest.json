{
  "manifest_version": 3,
  "name": "Aura Highlighter",
  "version": "1.0.0",
  "description": "Sleek, glassmorphic highlight management tool with contextual controls and smart persistent ranges.",
  "permissions": [
    "storage",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "content/utils.js",
        "content/highlighter.js",
        "content/floating-menu.js",
        "content/content.js"
      ],
      "css": ["content/content.css"]
    }
  ]
}
